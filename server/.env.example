# ════════════════════════════════════════════════════════════
# SnapSense Server Environment Variables
# ════════════════════════════════════════════════════════════

# ─── Database ────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/snapsense
# Or use MongoDB Atlas:
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/snapsense

# ─── Server Configuration ─────────────────────────────────────
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173
SESSION_SECRET=your-super-secret-session-key-change-this-in-production

# ─── Google OAuth ─────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:5000/auth/google/callback

# ─── AI Service (Groq) ────────────────────────────────────────
GROQ_API_KEY=your-groq-api-key

# ─── Lemon Squeezy Payment Integration ───────────────────────
# Get these from: https://app.lemonsqueezy.com/settings/api
LEMONSQUEEZY_API_KEY=your-lemonsqueezy-api-key
LEMONSQUEEZY_STORE_ID=your-store-id
LEMONSQUEEZY_VARIANT_ID=your-variant-id-for-pro-plan
LEMONSQUEEZY_WEBHOOK_SECRET=your-webhook-signing-secret

# ════════════════════════════════════════════════════════════
# Setup Instructions:
# ════════════════════════════════════════════════════════════
#
# 1. Copy this file to .env (do NOT commit .env to Git)
# 2. Fill in all the values above with your actual credentials
# 3. For Lemon Squeezy:
#    - Create a product "SnapSense Pro" at ₹399/month (INR)
#    - Set up webhook pointing to: https://your-domain.com/api/webhook/lemonsqueezy
#    - Subscribe to all events (order_created, subscription_*, etc.)
#    - Copy API key, Store ID, Variant ID, and Webhook Secret
# 4. Restart the server after updating .env
#
# ════════════════════════════════════════════════════════════
